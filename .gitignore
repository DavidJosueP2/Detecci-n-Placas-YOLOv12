# Keep model checkpoints versionable.
# If a checkpoint exceeds GitHub's 100 MB limit, move it to Git LFS or a release asset.
!*.pt
!modelos/**/*.pt

# Modelos grandes (>100 MB) que GitHub rechaza
models/lp_yolo11x_morsetech.pt
plate_detection_web/models/lp_yolo11x_morsetech.pt
plate_detection_web/models/Charcter-LP.pt

# last.pt no es necesario, best.pt es suficiente
**/weights/last.pt

