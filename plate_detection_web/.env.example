# Copia este archivo como .env y ajusta los valores segun tu equipo.

# Modelo principal de deteccion de placas.
PLATE_MODEL_PATH=models/90mil_50 epocas.pt

# Modelo OCR de caracteres.
CHARACTER_MODEL_PATH=models/Charcter-LP.pt

# Fuente inicial:
# - 0, 1, 2... para camaras locales o virtuales.
# - ruta local para un video.
VIDEO_SOURCE=0

# Cantidad de indices de camara a escanear para el menu Fuente.
# Si usas telefono como webcam y no aparece, prueba 15 o 20.
CAMERA_SCAN_LIMIT=10
CAMERA_BACKEND=msmf
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30
CAMERA_FOURCC=MJPG

# Inferencia YOLO.
CONFIDENCE_THRESHOLD=0.12
IMAGE_SIZE=512
YOLO_DEVICE=auto
YOLO_TRACKER=botsort.yaml
IOU_THRESHOLD=0.45

# Rendimiento del visor.
STREAM_TARGET_FPS=12
STREAM_MAX_WIDTH=960
DETECTION_EVERY_N_FRAMES=1
LIVE_DETECTION_INTERVAL_SECONDS=0.35

# Solo controla como se dibuja el visor en la web; no cambia el video real.
VIDEO_ASPECT_RATIO=16 / 9
VIDEO_MAX_WIDTH=860px

# OCR.
CHARACTER_CONFIDENCE_THRESHOLD=0.25
CHARACTER_IMAGE_SIZE=256
OCR_VARIANTS=2
OCR_INTERVAL_SECONDS=1.25
OCR_RETRY_INTERVAL_SECONDS=0.30
OCR_MAX_PLATES_PER_FRAME=1
OCR_MIN_DETECTION_CONFIDENCE=0.20

# Velocidad por dos lineas inclinadas.
# Coordenadas normalizadas:
# - X: 0.0 izquierda, 1.0 derecha.
# - Y: 0.0 arriba/fondo de la imagen, 1.0 abajo/cerca de la camara.
# Si RIGHT_Y es menor que LEFT_Y, la linea sube hacia la derecha.
SPEED_LINE_A_LEFT_Y=0.36
SPEED_LINE_A_RIGHT_Y=0.32
SPEED_LINE_B_LEFT_Y=0.66
SPEED_LINE_B_RIGHT_Y=0.63

# Compatibilidad con configuracion anterior. Se usan solo si no defines LEFT_Y/RIGHT_Y.
SPEED_LINE_A_Y=0.36
SPEED_LINE_B_Y=0.66

# Rango horizontal donde se dibujan y miden las lineas.
SPEED_ROI_X1=0.0
SPEED_ROI_X2=1.0

# Distancia real entre Linea A y Linea B sobre la via.
SPEED_DISTANCE_METERS=5.0
SPEED_DIRECTION=both
SPEED_LINE_HYSTERESIS_PX=8
SPEED_MIN_TRAVEL_TIME=0.15
SPEED_MAX_TRAVEL_TIME=8.0
SPEED_MIN_MOVEMENT_PX=35
SPEED_MIN_PARTIAL_PROGRESS=0.35

# Incidencias locales.
INCIDENT_DB_NAME=incidencias.sqlite3
INCIDENT_COOLDOWN_SECONDS=45

# Flask.
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=0
